setwd("~/Desktop/Postdoc/changepoint detection/geosphere")
prec_temp = read.csv("qnormc.csv", header = TRUE)[,-1]
r_thin = seq(15001, 20000, 10)
c.mean = apply(pnorm(as.matrix(prec_temp[r_thin,])), 2, mean)
cp_BH = round(as.vector(c.mean)*43)
xgrid = seq(300, 20, -10)
for(i in 1:length(cstd_data_list)){
png(paste("cstd_data", select_grids[i], ".png", sep = ""), height = 7, width = 9, res = 400, units="in")
par(mar=c(7,5,4,1)+.1)
obs = cstd_data_list[[i]]
nknot = dim(obs)[1]
plot(xgrid, obs[,1], xlim = c(max(xgrid), min(xgrid)), ylim = c(min(obs), max(obs)), xlab = "Pressure level (hPa)",
ylab = "Temperature Difference after Scaling (K)", type = "l", col = alpha("blue", 0.35),
cex.lab=2, cex.axis=1.5, cex.main=2.2, cex.sub=2, lwd = 1.8)
if(min(xgrid)>=50){at = c(350, 300, 250, 200, 150, 100, 50, 20)
}else{at=c(300, 250, 200, 150, 100,50, 20)}
axis(1, at=at, labels=as.character(at),cex.lab=2, cex.axis=1.5)
for(j in 2:Nt){
if(j <= cp_BH[i]){
lines(xgrid, obs[,j], col = alpha("blue", 0.35), lwd = 1.8)
}else{lines(xgrid, obs[,j], col = alpha("red", 0.35), lwd = 1.8)}
}
dev.off()
}
